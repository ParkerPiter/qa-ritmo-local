# Database Configuration
DB_USER=postgres
DB_URI=postgresql://user:password@localhost:5432/database_name
DB_PASSWORD=admin
DB_HOST=localhost
DB_NAME=ritmo-local
DB_PORT=5432

# Security
JWT_SECRET=your_jwt_secret_here

# Email Configuration (for local testing with Gmail)
EMAIL_ADMIN=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
AUTH_USER=your_gmail_app_password

# Resend API (for production email delivery)
RESEND_API_KEY=re_your_resend_api_key_here

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Ticketing microservice (Silver Glider Tickets) — integración S2S
# TICKETING_URL: base URL del microservicio de ticketing
# SERVICE_API_KEY: secreto compartido (mismo valor en el ticketing) para el header x-api-key
TICKETING_URL=http://localhost:3000
SERVICE_API_
